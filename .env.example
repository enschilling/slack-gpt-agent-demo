OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5.6

SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Optional: enables GitHub-backed repo summaries and issue creation.
GITHUB_TOKEN=github_pat_or_classic_token
GITHUB_OWNER=your-github-org-or-username
GITHUB_REPOS=repo-one,repo-two

# Optional: Open-Meteo works without an API key, so this can stay blank.
WEATHER_API_KEY=

# Optional: local demo data for the travel tool.
TRAVEL_DATA_PATH=demo_travel.json
PORT=8080
